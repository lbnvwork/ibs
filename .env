# Общие настройки
APP_ENV=dev
APP_DEBUG=true

# Настройки базы данных PostgreSQL
DATABASE_URL=postgresql://postgres:password@db:5432/mydatabase?serverVersion=15&charset=utf8

# Настройки почты (можно оставить по умолчанию)
MAILER_TRANSPORT=smtp
MAILER_HOST=127.0.0.1
MAILER_PORT=1025
MAILER_USER_NAME=null
MAILER_PASSWORD=null
MAILER_FROM_EMAIL=null
MAILER_FROM_NAME="Example"

# Настройки Symfony
SYMFONY_SECRET=your_secret_key

# Настройки API
API_PLATFORM_URL=/api

# Настройки Swagger
SWAGGER_DOC=true